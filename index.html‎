<script>
"use strict";
/* ============================================================
   מסך ניתוח מניות — Equity Research Desk
   Single-file. Data: Finnhub free tier. Model: rules-based.
   ============================================================ */
const BASE = "https://finnhub.io/api/v1";
const KEY_LS = "finnhub_api_key";
const RECENT_LS = "sa_recent_tickers";
const cache = {};            // symbol -> bundle
let busy = false;
let cmpChart=null, peersChart=null, peersData=[], liveTimer=null, liveSym=null;
let finSeries=null, finChart=null;

/* ---------- API key handling ---------- */
function getKey(){ return (localStorage.getItem(KEY_LS) || "").trim(); }
function setKey(k){ localStorage.setItem(KEY_LS, k.trim()); }
function refreshKeyStatus(){
  const k = getKey(), el = document.getElementById("keyStatus"), t = document.getElementById("keyStatusText");
  if(k){ el.classList.add("ok"); t.textContent = "מפתח מחובר · החלפה"; }
  else { el.classList.remove("ok"); t.textContent = "חיבור מפתח API"; }
}
function toggleKeyPanel(force){
  const p = document.getElementById("keyPanel");
  const show = force===true ? true : (force===false ? false : !p.classList.contains("show"));
  p.classList.toggle("show", show);
  if(show){ document.getElementById("keyInput").value = getKey(); document.getElementById("keyInput").focus(); }
}
function saveKey(){
  const v = document.getElementById("keyInput").value.trim();
  if(!v){ return; }
  setKey(v); refreshKeyStatus(); toggleKeyPanel(false);
  const tk = document.getElementById("ticker").value.trim();
  if(tk) run(); else showHero();
}

/* ---------- recent tickers ---------- */
function getRecent(){ try{ return JSON.parse(localStorage.getItem(RECENT_LS)||"[]"); }catch(e){ return []; } }
function pushRecent(sym){
  let r = getRecent().filter(x=>x!==sym); r.unshift(sym); r = r.slice(0,7);
  localStorage.setItem(RECENT_LS, JSON.stringify(r)); renderRecent();
}
function renderRecent(){
  const r = getRecent(), box = document.getElementById("recentChips");
  if(!r.length){ box.style.display="none"; return; }
  box.style.display="flex";
  box.innerHTML = '<span class="lbl">אחרונות:</span>' + r.map(s=>`<span class="chip" onclick="quick('${s}')">${s}</span>`).join("");
}

/* ---------- fetch layer ---------- */
async function api(path, params={}){
  const key = getKey();
  const qs = new URLSearchParams({...params, token:key}).toString();
  const res = await fetch(`${BASE}${path}?${qs}`);
  if(res.status===401 || res.status===403){ const e=new Error("auth"); e.code="auth"; throw e; }
  if(res.status===429){ const e=new Error("rate"); e.code="rate"; throw e; }
  if(!res.ok){ const e=new Error("http"+res.status); e.code="http"; throw e; }
  return res.json();
}

/* ---------- helpers: formatting ---------- */
const isNum = v => typeof v==="number" && isFinite(v);
function pick(obj, keys){ if(!obj) return null; for(const k of keys){ const v=obj[k]; if(isNum(v)) return v; } return null; }
function fmt(v, d=2){ return isNum(v) ? v.toLocaleString("en-US",{minimumFractionDigits:d,maximumFractionDigits:d}) : "—"; }
function fmtPx(v){ return isNum(v) ? "$"+v.toLocaleString("en-US",{minimumFractionDigits:2,maximumFractionDigits:2}) : "—"; }
function fmtPct(v,d=2){ return isNum(v) ? (v>=0?"+":"")+v.toFixed(d)+"%" : "—"; }
function fmtPctU(v,d=1){ return isNum(v) ? v.toFixed(d)+"%" : "—"; }      // unsigned %
function fmtX(v,d=1){ return isNum(v) ? v.toFixed(d)+"×" : "—"; }
function fmtCap(mln){ // value in millions USD
  if(!isNum(mln)) return "—";
  if(mln>=1e6) return "$"+(mln/1e6).toFixed(2)+"T";
  if(mln>=1e3) return "$"+(mln/1e3).toFixed(2)+"B";
  return "$"+mln.toFixed(0)+"M";
}
function esc(s){ return (s==null?"":String(s)).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c])); }
function clsUD(v){ return isNum(v) ? (v>=0?"up":"down") : ""; }

/* ---------- scoring engine ---------- */
// band: pairs ascending by threshold; returns score for first threshold >= v
function band(v, pairs){
  if(!isNum(v)) return null;
  for(const [mx,sc] of pairs){ if(v<=mx) return sc; }
  return pairs[pairs.length-1][1];
}
function wavg(items){ // [{score,weight}]
  let s=0,w=0; for(const it of items){ if(isNum(it.score)){ s+=it.score*it.weight; w+=it.weight; } }
  return w>0 ? s/w : null;
}
const avgDef = arr => { const a=arr.filter(isNum); return a.length? a.reduce((x,y)=>x+y,0)/a.length : null; };

// lower-is-better attractiveness scorers
const sPE = pe => (isNum(pe)&&pe>0) ? band(pe,[[10,100],[15,90],[20,80],[25,66],[30,52],[40,38],[60,22],[1e9,10]]) : null;
const sPS = ps => (isNum(ps)&&ps>0) ? band(ps,[[1,100],[2,86],[4,70],[6,54],[10,36],[20,20],[1e9,10]]) : null;
const sPB = pb => (isNum(pb)&&pb>0) ? band(pb,[[1,100],[2,86],[4,70],[6,54],[10,34],[1e9,18]]) : null;
const sGrowth = g => isNum(g) ? band(g,[[-20,5],[-5,22],[0,38],[5,52],[10,66],[20,80],[35,92],[1e9,100]]) : null;
const sMargin = m => isNum(m) ? band(m,[[0,12],[5,42],[10,60],[20,78],[30,90],[1e9,100]]) : null;
const sROE = r => isNum(r) ? band(r,[[0,10],[5,40],[10,56],[15,72],[25,88],[1e9,100]]) : null;
const sCurrent = c => isNum(c) ? band(c,[[1,34],[1.5,66],[2,84],[4,90],[1e9,78]]) : null;
const sDE_attr = d => isNum(d) ? band(d,[[0.3,100],[0.6,88],[1,74],[2,56],[3,36],[1e9,16]]) : null;
const sCover = c => isNum(c) ? band(c,[[1,10],[3,46],[6,70],[12,88],[1e9,100]]) : null;

// risk scorers (higher = riskier)
const rBeta = b => isNum(b) ? band(b,[[0.8,20],[1.1,40],[1.5,62],[2,84],[1e9,100]]) : null;
const rDE = d => isNum(d) ? band(d,[[0.3,15],[0.6,32],[1,50],[2,70],[3,86],[1e9,100]]) : null;
const rMargin = m => isNum(m) ? band(m,[[0,95],[5,70],[10,50],[20,30],[1e9,15]]) : null;
const rVal = pe => (isNum(pe)&&pe>0) ? band(pe,[[15,20],[25,36],[40,56],[60,76],[1e9,92]]) : (isNum(pe)?90:null);
const rLiq = c => isNum(c) ? band(c,[[1,85],[1.5,55],[2.5,28],[1e9,15]]) : null;
const rSize = mc => isNum(mc) ? band(mc,[[300,100],[2000,76],[10000,50],[50000,30],[1e9,15]]) : null;

function consensusFromRec(rec){
  if(!rec || !rec.length) return null;
  const r = rec[0];
  const tot = (r.strongBuy||0)+(r.buy||0)+(r.hold||0)+(r.sell||0)+(r.strongSell||0);
  if(!tot) return null;
  const c = (r.strongBuy*5 + r.buy*4 + r.hold*3 + r.sell*2 + r.strongSell*1)/tot; // 1..5
  let prev=null;
  for(let i=1;i<rec.length;i++){
    const p=rec[i], t=(p.strongBuy||0)+(p.buy||0)+(p.hold||0)+(p.sell||0)+(p.strongSell||0);
    if(t){ prev=(p.strongBuy*5+p.buy*4+p.hold*3+p.sell*2+p.strongSell*1)/t; if(i>=2) break; }
  }
  return {score:c, total:tot, latest:r, trend: prev!=null ? c-prev : null};
}

function buildModel(M, profile, rec){
  // extract metrics
  const pe = pick(M,["peTTM","peBasicExclExtraTTM","peNormalizedAnnual","peExclExtraTTM"]);
  const ps = pick(M,["psTTM","psAnnual"]);
  const pb = pick(M,["pbQuarterly","pbAnnual"]);
  const revG = pick(M,["revenueGrowthTTMYoy","revenueGrowthQuarterlyYoy","revenueGrowth3Y","revenueGrowth5Y"]);
  const epsG = pick(M,["epsGrowthTTMYoy","epsGrowthQuarterlyYoy","epsGrowth3Y","epsGrowth5Y"]);
  const netM = pick(M,["netProfitMarginTTM","netProfitMarginAnnual"]);
  const opM  = pick(M,["operatingMarginTTM","operatingMarginAnnual"]);
  const gM   = pick(M,["grossMarginTTM","grossMarginAnnual"]);
  const roe  = pick(M,["roeTTM","roeRfy","roeAnnual"]);
  const roa  = pick(M,["roaTTM","roaRfy","roaAnnual"]);
  const cur  = pick(M,["currentRatioQuarterly","currentRatioAnnual"]);
  const de   = pick(M,["totalDebt/totalEquityQuarterly","totalDebt/totalEquityAnnual","longTermDebt/equityQuarterly","longTermDebt/equityAnnual"]);
  const cover= pick(M,["netInterestCoverageTTM","netInterestCoverageAnnual"]);
  const beta = pick(M,["beta"]);
  const mc   = isNum(profile&&profile.marketCapitalization) ? profile.marketCapitalization : null;
  const cons = consensusFromRec(rec);

  // attractiveness factors
  const fVal = avgDef([sPE(pe),sPS(ps),sPB(pb)]);
  const fGro = avgDef([sGrowth(revG),sGrowth(epsG)]);
  const fPro = avgDef([sMargin(netM),sROE(roe),sMargin(opM)]);
  const fHea = avgDef([sCurrent(cur),sDE_attr(de),sCover(cover)]);
  const fAna = cons ? Math.max(0,Math.min(100,(cons.score-1)/4*100)) : null;

  const attrFactors = [
    {key:"val",label:"שווי / תמחור",en:"Valuation",weight:20,score:fVal,
      raw:`P/E ${isNum(pe)?pe.toFixed(1):"—"} · P/S ${isNum(ps)?ps.toFixed(1):"—"} · P/B ${isNum(pb)?pb.toFixed(1):"—"}`},
    {key:"gro",label:"צמיחה",en:"Growth",weight:20,score:fGro,
      raw:`הכנסות ${fmtPct(revG,1)} · EPS ${fmtPct(epsG,1)}`},
    {key:"pro",label:"רווחיות",en:"Profitability",weight:20,score:fPro,
      raw:`שולי נטו ${fmtPctU(netM)} · ROE ${fmtPctU(roe)}`},
    {key:"hea",label:"איתנות פיננסית",en:"Financial health",weight:15,score:fHea,
      raw:`יחס שוטף ${isNum(cur)?cur.toFixed(2):"—"} · חוב/הון ${isNum(de)?de.toFixed(2):"—"}`},
    {key:"ana",label:"סנטימנט אנליסטים",en:"Analyst sentiment",weight:15,score:fAna,
      raw: cons?`קונצנזוס ${cons.score.toFixed(2)}/5 (${cons.total})`:"אין כיסוי"},
  ];

  // risk factors
  const rfBeta=rBeta(beta), rfDE=rDE(de), rfMar=rMargin(netM), rfVal=rVal(pe), rfLiq=rLiq(cur), rfSize=rSize(mc);
  const riskFactors = [
    {key:"vol",label:"תנודתיות",en:"Volatility / Beta",weight:25,score:rfBeta, raw:`β ${isNum(beta)?beta.toFixed(2):"—"}`},
    {key:"lev",label:"מינוף",en:"Leverage",weight:20,score:rfDE, raw:`חוב/הון ${isNum(de)?de.toFixed(2):"—"}`},
    {key:"prr",label:"סיכון רווחיות",en:"Profitability",weight:20,score:rfMar, raw:`שולי נטו ${fmtPctU(netM)}`},
    {key:"var",label:"סיכון תמחור",en:"Valuation",weight:15,score:rfVal, raw:`P/E ${isNum(pe)?pe.toFixed(1):"—"}`},
    {key:"liq",label:"נזילות",en:"Liquidity",weight:10,score:rfLiq, raw:`יחס שוטף ${isNum(cur)?cur.toFixed(2):"—"}`},
    {key:"siz",label:"גודל חברה",en:"Size",weight:10,score:rfSize, raw:fmtCap(mc)},
  ];

  return {
    metrics:{pe,ps,pb,revG,epsG,netM,opM,gM,roe,roa,cur,de,cover,beta,mc},
    cons, attrFactors, riskFactors,
    attrScore: wavg(attrFactors),
    riskScore: wavg(riskFactors),
  };
}

// add momentum factor once we know price + 52w (keeps weights consistent)
function addMomentum(model, price, hi, lo){
  if(isNum(price)&&isNum(hi)&&isNum(lo)&&hi>lo){
    const p=(price-lo)/(hi-lo);
    const sc = band(p,[[0.15,42],[0.30,62],[0.45,80],[0.70,95],[0.85,82],[1.01,64]]);
    model.attrFactors.push({key:"mom",label:"מומנטום / מיקום בטווח",en:"52-wk position",weight:10,score:sc,
      raw:`${(p*100).toFixed(0)}% מהטווח השנתי`});
    model.attrScore = wavg(model.attrFactors);
  }
}

function attrBand(s){
  if(!isNum(s)) return {t:"—",cls:"t-neu"};
  if(s>=80) return {t:"אטרקטיביות גבוהה",cls:"t-good"};
  if(s>=65) return {t:"אטרקטיביות טובה",cls:"t-good"};
  if(s>=45) return {t:"אטרקטיביות בינונית",cls:"t-ok"};
  if(s>=30) return {t:"מתחת לממוצע",cls:"t-ok"};
