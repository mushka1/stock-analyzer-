/* ---------- gauge (semicircular) ---------- */
function drawGauge(score){
  const svg=document.getElementById("gauge"); if(!svg) return;
  const cx=100,cy=105,r=80, start=Math.PI, end=0;
  function pt(a){ return [cx+r*Math.cos(a), cy-r*Math.sin(a)]; }
  function arc(a0,a1,color,w){
    const [x0,y0]=pt(a0),[x1,y1]=pt(a1); const large=(a0-a1)>Math.PI?1:0;
    return `<path d="M ${x0} ${y0} A ${r} ${r} 0 ${large} 1 ${x1} ${y1}" stroke="${color}" stroke-width="${w}" fill="none" stroke-linecap="round"/>`;
  }
  let html="";
  html+=arc(start,end,"#22324c",14);                 // track
  if(isNum(score)){
    const frac=Math.max(0,Math.min(1,score/100));
    const a1=start-(start-end)*frac;
    html+=arc(start,a1,scoreColor(score),14);
    const [nx,ny]=pt(a1);
    html+=`<circle cx="${nx}" cy="${ny}" r="8" fill="#131e30" stroke="${scoreColor(score)}" stroke-width="4"/>`;
  }
  html+=`<text x="22" y="118" font-size="10" fill="#71849e" font-family="Inter">0</text>`;
  html+=`<text x="170" y="118" font-size="10" fill="#71849e" font-family="Inter">100</text>`;
  svg.innerHTML=html;
}

/* ---------- peers comparison (async) ---------- */
async function loadPeers(sym, peerList){
  const card=document.getElementById("peersCard"); if(!card) return;
  let list=[...new Set((peerList||[]).filter(s=>s && s!==sym))].slice(0,5);
  if(!list.length){ peersData=[]; card.innerHTML=`<h2 class="ctitle"><span class="ico">⚔️</span>מתחרים <span class="wlbl">Peers</span></h2><div class="badge-na">לא נמצאו מתחרים ישירים בנתוני Finnhub.</div>`; return; }
  const self=cache[sym];
  const data=[{sym, Q:self.Q, P:self.P, M:self.M, model:self.model, self:true}];
  const results=await Promise.allSettled(list.map(async s=>{
    const [q,p,m]=await Promise.allSettled([api("/quote",{symbol:s}),api("/stock/profile2",{symbol:s}),api("/stock/metric",{symbol:s,metric:"all"})]);
    return {s, Q:val(q), P:val(p), M:unwrapMetric(val(m))};
  }));
  for(const r of results){ if(r.status==="fulfilled" && r.value){ const d=r.value; const mdl=buildModel(d.M,d.P,[]); addMomentum(mdl, d.Q&&d.Q.c, d.M["52WeekHigh"], d.M["52WeekLow"]); data.push({sym:d.s,Q:d.Q,P:d.P,M:d.M,model:mdl,self:false}); } }
  peersData=data;
  const rows=data.map(d=>{
    const px=d.Q&&d.Q.c, mc=d.P&&d.P.marketCapitalization, pe=d.model.metrics.pe, nm=d.model.metrics.netM, yr=pick(d.M,["52WeekPriceReturnDaily"]), sc=d.model.attrScore;
    const main=`<tr class="${d.self?'self':'prow'}"${d.self?'':` onclick="togglePeer('${esc(d.sym)}')"`}>
      <td class="n pt">${d.self?'★ ':''}${esc(d.sym)}</td>
      <td class="num">${fmtPx(px)}</td><td class="num">${fmtCap(mc)}</td>
      <td class="num">${isNum(pe)?pe.toFixed(1):"—"}</td><td class="num">${fmtPctU(nm)}</td>
      <td class="num ${clsUD(yr)}">${fmtPct(yr,1)}</td>
      <td class="num" style="font-weight:700;color:${scoreColor(sc)}">${isNum(sc)?Math.round(sc):"—"}</td>
    </tr>`;
    if(d.self) return main;
    const a=attrBand(d.model.attrScore), rk=riskBand(d.model.riskScore);
    const detail=`<tr class="peer-detail" id="pd-${esc(d.sym)}" style="display:none"><td colspan="7"><div class="pd-box">
      <div class="pd-name">${esc((d.P&&d.P.name)||d.sym)} <span class="pd-tk ltr">${esc(d.sym)}</span></div>
      <div class="pd-grid"><span>ענף: ${d.P&&d.P.finnhubIndustry?esc(d.P.finnhubIndustry):"—"}</span><span>דירוג מודל: <b>${a.t}</b> · ${rk.t}</span><span>תשואת שנה: <b class="${clsUD(yr)}">${fmtPct(yr,1)}</b></span><span>שולי נטו: <b>${fmtPctU(nm)}</b></span><span>ROE: <b>${fmtPctU(d.model.metrics.roe)}</b></span><span>חוב/הון: <b>${isNum(d.model.metrics.de)?d.model.metrics.de.toFixed(2):"—"}</b></span></div>
      <button class="pd-btn" onclick="event.stopPropagation();quick('${esc(d.sym)}')">נתח מניה זו ↗</button>
    </div></td></tr>`;
    return main+detail;
  }).join("");
  card.innerHTML=`<h2 class="ctitle"><span class="ico">⚔️</span>מתחרים והשוואה ענפית <span class="wlbl">Peers</span></h2>
    <p class="csub">לחצי על שורת מתחרה לפרטים ולניתוח מלא. ★ = המניה הנבחנת.</p>
    <div class="peer-chart-head"><span>גרף לפי:</span><select id="peerMetric" onchange="drawPeersChart()"><option value="score">ציון המודל</option><option value="ret1y">תשואת שנה</option><option value="pe">מכפיל רווח (P/E)</option><option value="nm">שולי רווח נקי</option></select></div>
    <div class="cmpwrap"><canvas id="peersCanvas"></canvas></div>
    <div style="overflow-x:auto;margin-top:14px"><table class="peers">
      <thead><tr><th class="n">טיקר</th><th>מחיר</th><th>שווי שוק</th><th>P/E</th><th>שולי נטו</th><th>תשואה שנתית</th><th>ציון</th></tr></thead>
      <tbody>${rows}</tbody>
    </table></div>`;
  drawPeersChart();
}
function peerRow(sym,Q,P,M,model,isSelf){
  const px=Q&&Q.c, mc=P&&P.marketCapitalization, pe=model.metrics.pe, nm=model.metrics.netM;
  const yr=pick(M,["52WeekPriceReturnDaily"]);
  const sc=model.attrScore;
  return `<tr class="${isSelf?'self':''}">
    <td class="n pt">${esc(sym)}</td>
    <td class="num">${fmtPx(px)}</td>
    <td class="num">${fmtCap(mc)}</td>
    <td class="num">${isNum(pe)?pe.toFixed(1):"—"}</td>
    <td class="num">${fmtPctU(nm)}</td>
    <td class="num ${clsUD(yr)}">${fmtPct(yr,1)}</td>
    <td class="num" style="font-weight:700;color:${scoreColor(sc)}">${isNum(sc)?Math.round(sc):"—"}</td>
  </tr>`;
}

