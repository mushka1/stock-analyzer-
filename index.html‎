<html lang="he" dir="rtl"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>מסך ניתוח מניות · Equity Research Desk</title>
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
<link href="./מסך ניתוח מניות · Equity Research Desk_files/css2" rel="stylesheet">
<script src="./מסך ניתוח מניות · Equity Research Desk_files/chart.umd.min.js"></script>
<style>
  :root{
    /* dark theme */
    --navy:#0d1626; --navy2:#16263f;
    --head:#eaf1fb; --ink:#d7e2f0; --muted:#9db0c8; --muted2:#71849e;
    --bg:#0a111e; --card:#131e30; --card2:#0f1827; --line:#27374f; --line2:#1d2b41;
    --input:#0e1828; --chip:#1a2840;
    --green:#37d39b; --green-bg:#10271f; --red:#f6726a; --red-bg:#2a1417;
    --amber:#f4b35a; --amber-bg:#2a2113; --gray:#9db0c8; --gray-bg:#1a2840;
    --accent:#3f86f4; --accent-bg:#122441; --selfrow:#172a46;
    --shadow:0 1px 2px rgba(0,0,0,.45),0 12px 34px rgba(0,0,0,.40);
    --radius:16px;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{
    font-family:'Heebo','Segoe UI',Arial,sans-serif;
    background:var(--bg); color:var(--ink); line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }
  .ltr{direction:ltr;unicode-bidi:isolate}
  .num{direction:ltr;unicode-bidi:isolate;font-family:'Inter','Heebo',sans-serif;font-variant-numeric:tabular-nums}
  a{color:var(--accent);text-decoration:none}
  a:hover{text-decoration:underline}

  /* Header */
  header.top{background:linear-gradient(135deg,#0e1d33,#16263f);color:#fff;padding:18px 0;border-bottom:1px solid var(--line)}
  .wrap{max-width:1140px;margin:0 auto;padding:0 20px}
  .top-row{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
  .brand{display:flex;align-items:center;gap:12px}
  .brand .logo{width:42px;height:42px;border-radius:11px;background:rgba(255,255,255,.10);display:flex;align-items:center;justify-content:center;font-size:22px}
  .brand h1{font-size:20px;font-weight:800;margin:0;letter-spacing:-.2px;color:#fff}
  .brand .sub{font-size:12.5px;color:#9fb4d6;margin-top:1px}
  .key-status{display:flex;align-items:center;gap:8px;font-size:12.5px;color:#bcccea;cursor:pointer;background:rgba(255,255,255,.08);padding:7px 12px;border-radius:10px;border:1px solid var(--line)}
  .key-status .dot{width:8px;height:8px;border-radius:50%;background:#f1c40f}
  .key-status.ok .dot{background:#39d98a}

  /* Search */
  .search-wrap{max-width:1140px;margin:-26px auto 0;padding:0 20px;position:relative;z-index:5}
  .search-card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:16px;border:1px solid var(--line)}
  .search-row{display:flex;gap:10px;flex-wrap:wrap}
  .search-row .field{flex:1;min-width:220px;display:flex;align-items:center;gap:10px;background:var(--input);border:1.5px solid var(--line);border-radius:12px;padding:0 14px}
  .search-row .field:focus-within{border-color:var(--accent);background:#0c1726}
  .search-row input{flex:1;border:0;background:transparent;color:var(--head);font-size:18px;font-weight:700;padding:13px 0;outline:none;font-family:'Inter',sans-serif;letter-spacing:1px;text-transform:uppercase;direction:ltr}
  .search-row input::placeholder{font-weight:500;letter-spacing:0;text-transform:none;color:var(--muted2)}
  .btn{border:0;border-radius:12px;padding:0 24px;font-size:16px;font-weight:700;cursor:pointer;font-family:inherit}
  .btn-primary{background:var(--accent);color:#fff}
  .btn-primary:hover{background:#5a98f6}
  .btn-primary:disabled{opacity:.5;cursor:default}
  .chips{display:flex;gap:7px;flex-wrap:wrap;margin-top:11px;align-items:center}
  .chips .lbl{font-size:12.5px;color:var(--muted)}
  .chip{font-family:'Inter',sans-serif;font-weight:600;font-size:13px;background:var(--chip);color:#cfe0fb;border:1px solid var(--line);padding:5px 11px;border-radius:20px;cursor:pointer}
  .chip:hover{background:var(--accent-bg);border-color:var(--accent)}

  /* Key panel */
  .keypanel{display:none;background:var(--accent-bg);border:1px solid var(--line);border-radius:14px;padding:16px;margin-top:13px}
  .keypanel.show{display:block}
  .keypanel h3{margin:0 0 6px;font-size:15.5px;color:var(--head)}
  .keypanel p{margin:0 0 10px;font-size:13.5px;color:var(--muted)}
  .keypanel ol{margin:0 0 12px;padding-inline-start:20px;font-size:13.5px;color:var(--muted)}
  .keypanel li{margin-bottom:3px}
  .keyrow{display:flex;gap:8px;flex-wrap:wrap}
  .keyrow input{flex:1;min-width:220px;background:var(--input);color:var(--head);border:1.5px solid var(--line);border-radius:10px;padding:11px 13px;font-family:'Inter',sans-serif;font-size:14px;direction:ltr;outline:none}
  .keyrow input:focus{border-color:var(--accent)}
  .keyrow .btn{background:var(--accent);color:#fff;padding:0 20px}
  .keyhint{font-size:12px;color:var(--muted2);margin-top:8px}

  /* Layout */
  main{max-width:1140px;margin:22px auto 60px;padding:0 20px}
  .status{text-align:center;padding:60px 20px;color:var(--muted)}
  .spinner{width:38px;height:38px;border:4px solid var(--line2);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}
  @keyframes spin{to{transform:rotate(360deg)}}
  .err{background:var(--red-bg);border:1px solid #5a2a2c;color:#f6b6b0;border-radius:14px;padding:16px 18px;font-size:14.5px}
  .hero-empty{text-align:center;padding:50px 20px;color:var(--muted)}
  .hero-empty .big{font-size:52px;margin-bottom:8px}
  .hero-empty h2{color:var(--head);font-size:21px;margin:0 0 6px}

  .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:18px}
  .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:20px}
  .card h2.ctitle{font-size:15px;font-weight:700;color:var(--head);margin:0 0 4px;display:flex;align-items:center;gap:8px}
  .card .csub{font-size:12px;color:var(--muted2);margin:0 0 15px}
  .ctitle .ico{font-size:17px}
  .col-12{grid-column:span 12}
  .col-8{grid-column:span 8}
  .col-7{grid-column:span 7}
  .col-6{grid-column:span 6}
  .col-5{grid-column:span 5}
  .col-4{grid-column:span 4}
  @media(max-width:860px){.col-8,.col-7,.col-6,.col-5,.col-4{grid-column:span 12}}

  /* Company header */
  .company{display:flex;gap:16px;align-items:center;flex-wrap:wrap}
  .company .clogo,.lead-side .clogo{width:60px;height:60px;border-radius:14px;background:#eef3fb;border:1px solid var(--line);object-fit:contain;padding:6px;flex-shrink:0}
  .company .cinfo{flex:1;min-width:200px}
  .company .cname{font-size:22px;font-weight:800;color:var(--head);line-height:1.2}
  .company .cmeta{font-size:13px;color:var(--muted);margin-top:3px;display:flex;gap:10px;flex-wrap:wrap}
  .company .cmeta .tk{font-family:'Inter',sans-serif;font-weight:700;color:#cfe0fb;background:var(--chip);padding:1px 8px;border-radius:6px}
  .company .cmeta .sep{color:#3a4a63}
  .price-block{text-align:left;min-width:150px}
  .price-block .px{font-size:30px;font-weight:800;font-family:'Inter',sans-serif;color:var(--head)}
  .price-block .chg{font-size:15px;font-weight:600;font-family:'Inter',sans-serif;margin-top:2px}
  .up{color:var(--green)} .down{color:var(--red)}

  /* Verdict */
  .verdict{display:grid;grid-template-columns:230px 1fr;gap:22px;align-items:center}
  @media(max-width:680px){.verdict{grid-template-columns:1fr}}
  .gauge-wrap{text-align:center}
  .gauge-score{font-size:40px;font-weight:800;font-family:'Inter',sans-serif;line-height:1;margin-top:-6px}
  .gauge-label{font-size:14px;font-weight:700;margin-top:4px}
  .gauge-cap{font-size:11.5px;color:var(--muted2);margin-top:2px}
  .vbody .risk-badge{display:inline-flex;align-items:center;gap:7px;font-weight:700;font-size:14px;padding:7px 14px;border-radius:10px;margin-bottom:10px}
  .vsummary{font-size:14px;color:var(--ink);background:var(--card2);border:1px solid var(--line2);border-radius:12px;padding:13px 15px;margin-bottom:12px}
  .vsummary b{color:var(--head)}
  .factor-mini{display:flex;gap:7px;flex-wrap:wrap}
  .fm{font-size:11.5px;padding:4px 9px;border-radius:8px;font-weight:600;border:1px solid transparent}

  /* Tags */
  .t-good{background:var(--green-bg);color:var(--green)}
  .t-ok{background:var(--amber-bg);color:var(--amber)}
  .t-weak{background:var(--red-bg);color:var(--red)}
  .t-neu{background:var(--gray-bg);color:var(--muted)}
  .dot-tag{display:inline-block;width:9px;height:9px;border-radius:50%;margin-inline-start:6px;vertical-align:middle}
  .d-good{background:var(--green)} .d-ok{background:var(--amber)} .d-weak{background:var(--red)} .d-neu{background:var(--muted2)}

  /* Move analysis */
  .movecard{border-inline-start:4px solid var(--line)}
  .movecard.sig-up{border-inline-start-color:var(--green)}
  .movecard.sig-down{border-inline-start-color:var(--red)}
  .move-rows{display:flex;gap:14px;flex-wrap:wrap;margin:4px 0 12px}
  .move-row{flex:1;min-width:210px;background:var(--input);border:1px solid var(--line2);border-radius:12px;padding:12px 14px}
  .move-row .mh{font-size:12px;color:var(--muted)}
  .move-row .mbig{font-size:23px;font-weight:800;font-family:'Inter',sans-serif;margin:2px 0}
  .move-row .msub{font-size:12px;color:var(--muted2);font-family:'Inter',sans-serif}
  .move-flag{display:inline-block;font-size:11.5px;font-weight:700;padding:3px 9px;border-radius:7px;margin-top:7px}
  .move-detail{font-size:13.5px;color:var(--ink);background:var(--card2);border:1px solid var(--line2);border-radius:12px;padding:12px 14px;line-height:1.65}
  .move-detail b{color:var(--head)}
  .move-note{font-size:11.5px;color:var(--muted2);margin-top:10px}

  /* Metrics grid */
  .mgroup{margin-bottom:16px}
  .mgroup:last-child{margin-bottom:0}
  .mgroup .gh{font-size:12.5px;font-weight:700;color:var(--head);text-transform:uppercase;letter-spacing:.4px;margin-bottom:9px;padding-bottom:6px;border-bottom:1px solid var(--line2)}
  .metrics{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:11px}
  .metric{background:var(--input);border:1px solid var(--line2);border-radius:11px;padding:10px 12px}
  .metric .ml{font-size:11.5px;color:var(--muted);display:flex;align-items:center;justify-content:space-between;gap:4px}
  .metric .ml .en{font-family:'Inter',sans-serif;color:var(--muted2);font-size:10.5px}
  .metric .mv{font-size:18px;font-weight:700;font-family:'Inter',sans-serif;margin-top:3px;color:var(--head)}

  /* Range bars */
  .range{margin:14px 0}
  .range .rl{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:6px}
  .range .rl .rlab{color:var(--ink);font-weight:600}
  .track{position:relative;height:9px;background:#1a2740;border-radius:6px}
  .track .fill{position:absolute;top:0;bottom:0;right:0;background:linear-gradient(90deg,var(--navy2),var(--accent));border-radius:6px}
  .track .mark{position:absolute;top:-5px;width:4px;height:19px;background:var(--head);border-radius:3px;transform:translateX(50%);box-shadow:0 0 0 3px var(--card)}
  .ends{display:flex;justify-content:space-between;font-size:12px;font-family:'Inter',sans-serif;color:var(--muted);margin-top:6px;direction:ltr}
  .returns{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}
  .ret{flex:1;min-width:70px;text-align:center;background:var(--input);border:1px solid var(--line2);border-radius:10px;padding:8px 4px}
  .ret .rk{font-size:11px;color:var(--muted)}
  .ret .rv{font-size:14.5px;font-weight:700;font-family:'Inter',sans-serif;margin-top:2px}

  /* Breakdown tables */
  .bd-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
  @media(max-width:760px){.bd-grid{grid-template-columns:1fr}}
  .bd h4{font-size:13.5px;color:var(--head);margin:0 0 10px;display:flex;align-items:center;justify-content:space-between}
  .bd h4 .score-pill{font-family:'Inter',sans-serif;font-size:13px;background:var(--navy2);color:#0a111e;padding:3px 11px;border-radius:20px;font-weight:700}
  table.bdt{width:100%;border-collapse:collapse;font-size:13px}
  table.bdt td{padding:8px 4px;border-bottom:1px solid var(--line2);vertical-align:middle}
  table.bdt tr:last-child td{border-bottom:0}
  .bdt .f-name{font-weight:600;color:var(--ink)}
  .bdt .f-name small{display:block;font-weight:400;color:var(--muted2);font-size:10.5px;font-family:'Inter',sans-serif}
  .bdt .f-raw{font-family:'Inter',sans-serif;color:var(--muted);font-size:12px;text-align:left;white-space:nowrap}
  .barcell{width:120px}
  .minibar{position:relative;height:7px;background:var(--line2);border-radius:5px;overflow:hidden}
  .minibar .mf{position:absolute;top:0;bottom:0;right:0;border-radius:5px}
  .wlbl{font-size:10.5px;color:var(--muted2);font-family:'Inter',sans-serif}

  /* Analysts */
  .recbar{display:flex;height:30px;border-radius:9px;overflow:hidden;margin:6px 0 12px;border:1px solid var(--line2)}
  .recbar span{display:flex;align-items:center;justify-content:center;font-size:11.5px;font-weight:700;color:#06140e;font-family:'Inter',sans-serif;min-width:0}
  .rc-sb{background:#1fae74}.rc-b{background:#56c08a}.rc-h{background:#d6a93f}.rc-s{background:#e5824f}.rc-ss{background:#dd5247}
  .reclegend{display:flex;gap:6px;flex-wrap:wrap;font-size:11px;color:var(--muted)}
  .reclegend i{display:inline-block;width:9px;height:9px;border-radius:2px;margin-inline-start:4px}
  .consensus{font-size:15px;font-weight:700;margin-bottom:3px;color:var(--head)}
  .trendline{font-size:12.5px;color:var(--muted)}

  /* Peers */
  table.peers{width:100%;border-collapse:collapse;font-size:13px}
  table.peers th{text-align:right;font-size:11px;color:var(--muted);font-weight:600;padding:8px 6px;border-bottom:2px solid var(--line)}
  table.peers th.n,table.peers td.n{text-align:left;font-family:'Inter',sans-serif}
  table.peers td{padding:9px 6px;border-bottom:1px solid var(--line2)}
  table.peers tr:last-child td{border-bottom:0}
  table.peers .pt{font-weight:700;font-family:'Inter',sans-serif;color:#cfe0fb}
  table.peers tr.self{background:var(--selfrow)}

  /* News */
  .news-hotgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
  @media(max-width:760px){.news-hotgrid{grid-template-columns:1fr}}
  .hotcard{background:var(--input);border:1px solid var(--line2);border-radius:13px;padding:13px 14px;display:flex;flex-direction:column;gap:7px}
  .hotcard .hhead{display:flex;align-items:center;justify-content:space-between;gap:6px}
  .fire{font-size:11px;font-weight:800;color:#ffd9a0;background:#3a2a12;border:1px solid #5a4220;padding:2px 8px;border-radius:7px}
  .hotcard .htitle{font-size:13.5px;font-weight:700;color:var(--head);line-height:1.4}
  .hotcard .htitle a{color:var(--head)}
  .hotcard .hsum{font-size:12.5px;color:var(--muted);line-height:1.55}
  .hotcard .hmeta{font-size:11px;color:var(--muted2);margin-top:auto;font-family:'Inter',sans-serif}
  .news-sub{font-size:12.5px;font-weight:700;color:var(--head);margin:4px 0 6px;padding-top:12px;border-top:1px solid var(--line2)}
  .news-item{display:flex;gap:13px;padding:11px 0;border-bottom:1px solid var(--line2)}
  .news-item:last-child{border-bottom:0}
  .news-item .nthumb{width:64px;height:48px;border-radius:9px;object-fit:cover;background:var(--input);flex-shrink:0}
  .news-item .nbody{flex:1;min-width:0}
  .news-item .nhead{font-size:13.5px;font-weight:600;color:var(--ink);line-height:1.35}
  .news-item .nhead a{color:var(--ink)}
  .news-item .nmeta{font-size:11.5px;color:var(--muted2);margin-top:4px;display:flex;gap:9px;align-items:center;flex-wrap:wrap}
  .news-item .nsource{font-family:'Inter',sans-serif}
  .sent{font-size:10.5px;font-weight:700;padding:2px 7px;border-radius:6px}

  .disclaimer{font-size:11.5px;color:var(--muted2);line-height:1.6;background:var(--card2);border:1px solid var(--line2);border-radius:12px;padding:13px 15px;margin-top:4px}
  .disclaimer b{color:var(--muted)}
  footer{text-align:center;font-size:12px;color:var(--muted2);padding:24px 20px 40px}
  footer .ts{font-family:'Inter',sans-serif}
  .badge-na{font-size:12px;color:var(--muted2);background:var(--card2);border:1px dashed var(--line);border-radius:10px;padding:11px 13px}

  /* ===== newspaper masthead ===== */
  .masthead{padding:22px 26px}
  .nameplate{text-align:center;font-family:'Frank Ruhl Libre',Georgia,serif;font-weight:900;font-size:25px;letter-spacing:1px;color:var(--head);border-top:3px double var(--muted2);border-bottom:1px solid var(--muted2);padding:8px 0}
  .nameplate .np-sub{font-family:'Inter',sans-serif;font-weight:600;font-size:10.5px;letter-spacing:3px;color:var(--muted2);display:block;margin-top:3px}
  .dateline{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;font-size:11px;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);padding:7px 0;border-bottom:1px solid var(--line);margin-bottom:16px}
  .dateline .ltr{text-transform:none}
  .lead{display:grid;grid-template-columns:1fr 188px;gap:22px;align-items:start}
  @media(max-width:680px){.lead{grid-template-columns:1fr}}
  .kicker{font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);margin-bottom:6px}
  .headline{font-family:'Frank Ruhl Libre',Georgia,serif;font-weight:900;font-size:34px;line-height:1.15;color:var(--head);margin:0 0 9px}
  @media(max-width:680px){.headline{font-size:26px}}
  .standfirst{font-family:'Frank Ruhl Libre',Georgia,serif;font-size:16px;color:var(--ink);margin-bottom:13px;font-weight:500}
  .lede{font-family:'Frank Ruhl Libre',Georgia,serif;font-size:15px;line-height:1.8;color:var(--ink);margin:0 0 12px;border-top:1px solid var(--line2);padding-top:13px}
  .lede.has-text::first-letter{font-size:2.9em;font-weight:900;float:right;line-height:.82;margin-inline-end:9px;color:var(--accent)}
  .lede-na{color:var(--muted2);font-family:'Heebo',sans-serif;font-size:13px}
  .byline{font-size:12px;color:var(--muted2);border-top:1px solid var(--line2);padding-top:9px}
  .byline a{color:var(--accent)} .byline .sep{color:#3a4a63}
  .lead-side{display:flex;flex-direction:column;align-items:center;gap:10px;border-inline-start:1px solid var(--line);padding-inline-start:18px}
  .lead-side .price-block{text-align:center;min-width:0}
  @media(max-width:680px){.lead-side{border-inline-start:0;border-top:1px solid var(--line);padding-inline-start:0;padding-top:14px;flex-direction:row;justify-content:space-between;width:100%}}

  /* newspaper kicker on card titles */
  .card h2.ctitle{border-bottom:1px solid var(--line2);padding-bottom:9px;letter-spacing:.2px}
  .card h2.ctitle .wlbl{margin-inline-start:auto;text-transform:uppercase;letter-spacing:1.5px}

  /* ===== tooltips ===== */
  .tipi{display:inline-flex;align-items:center;justify-content:center;width:15px;height:15px;font-size:10px;font-weight:700;border-radius:50%;background:var(--accent-bg);color:#9cc2fb;border:1px solid var(--line);margin-inline-start:5px;cursor:help;font-family:'Inter',sans-serif;vertical-align:middle;user-select:none}
  .tipi:hover{background:var(--accent);color:#fff}
