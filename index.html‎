function verdictCard(model){
  const a=attrBand(model.attrScore), r=riskBand(model.riskScore);
  const mini = model.attrFactors.filter(f=>isNum(f.score)).sort((x,y)=>y.score-x.score);
  const top = mini.slice(0,2), bottom = mini.slice(-2).reverse();
  const chip = (f,good)=>`<span class="fm ${good?'t-good':'t-weak'}">${good?'▲':'▼'} ${f.label} ${Math.round(f.score)}</span>`;
  const summary = buildSummary(model,a,r);
  return `<div class="card col-12">
    <h2 class="ctitle"><span class="ico">🎯</span>סיכום המודל <span class="wlbl">Model verdict</span></h2>
    <div class="verdict">
      <div class="gauge-wrap">
        <svg id="gauge" width="200" height="120" viewBox="0 0 200 120"></svg>
        <div class="gauge-score" id="gaugeScore" style="color:${scoreColor(model.attrScore)}">${isNum(model.attrScore)?Math.round(model.attrScore):"—"}</div>
        <div class="gauge-label" style="color:${scoreColor(model.attrScore)}">${a.t}</div>
        <div class="gauge-cap">ציון אטרקטיביות (0–100) ${tipi("attr")}</div>
      </div>
      <div class="vbody">
        <div class="risk-badge ${r.cls}">דירוג סיכון ${tipi("risk")}: ${r.t} ${isNum(model.riskScore)?`· ${Math.round(model.riskScore)}/100`:""}</div>
        <div class="vsummary">${summary}</div>
        <div class="factor-mini">
          ${top.map(f=>chip(f,true)).join("")}
          ${bottom.map(f=>chip(f,false)).join("")}
        </div>
      </div>
    </div>
  </div>`;
}

function buildSummary(model,a,r){
  const m=model.metrics, parts=[];
  const strong = model.attrFactors.filter(f=>isNum(f.score)&&f.score>=70).map(f=>f.label);
  const weak = model.attrFactors.filter(f=>isNum(f.score)&&f.score<45).map(f=>f.label);
  parts.push(`לפי המודל הכמותי, המניה מקבלת ציון אטרקטיביות <b>${isNum(model.attrScore)?Math.round(model.attrScore):"—"}/100</b> (${a.t}) עם <b>${r.t}</b>.`);
  if(strong.length) parts.push(`חוזקות בולטות: ${strong.join(", ")}.`);
  if(weak.length) parts.push(`נקודות לתשומת לב: ${weak.join(", ")}.`);
  if(model.cons) parts.push(`קונצנזוס האנליסטים עומד על ${model.cons.score.toFixed(2)} מתוך 5 (${model.cons.total} ממליצים)${isNum(model.cons.trend)?(model.cons.trend>0?", במגמת שיפור":model.cons.trend<0?", במגמת החלשה":""):""}.`);
  return parts.join(" ");
}

/* ---------- price-move analysis card ---------- */
function moveCard(Q, M, NEWS){
  const a = moveAnalysis(Q, M, NEWS);
  if(!isNum(a.dp) && !isNum(a.r5)) return "";
  const sigClass = a.significant ? (a.dp>=0?"sig-up":"sig-down") : "";
  const flagFor = (lvl,dir)=>{
    if(!lvl) return "";
    if(lvl==="normal") return `<span class="move-flag t-neu">במסגרת הנורמה</span>`;
    const cls = dir>=0?"t-good":"t-weak";
    const word = lvl==="extreme"?"תנועה חריגה מאוד":"תנועה חריגה";
    return `<span class="move-flag ${cls}">${dir>=0?"▲":"▼"} ${word}</span>`;
  };
  const dayRow = isNum(a.dp) ? `<div class="move-row">
      <div class="mh">תנועת היום</div>
      <div class="mbig ${clsUD(a.dp)}">${fmtPct(a.dp,2)}</div>
      <div class="msub">תנודה יומית טיפוסית: ±${a.sigma.toFixed(1)}% · פי ${a.ratioDay.toFixed(1)} מהרגיל</div>
      ${flagFor(a.dayLvl,a.dayDir)}
    </div>` : "";
  const wkRow = isNum(a.r5) ? `<div class="move-row">
      <div class="mh">5 ימי מסחר</div>
      <div class="mbig ${clsUD(a.r5)}">${fmtPct(a.r5,2)}</div>
      <div class="msub">טווח שבועי טיפוסי: ±${a.sig5.toFixed(1)}% · פי ${a.ratio5.toFixed(1)} מהרגיל</div>
      ${flagFor(a.lvl5,a.dir5)}
    </div>` : "";

  let detail="";
  if(a.significant){
    const dirWord = a.dp>=0 ? "עלתה" : "ירדה";
    const lvlWord = (a.dayLvl==="extreme"||a.lvl5==="extreme") ? "חריגה מאוד (מעל 3 סטיות תקן)" : "חריגה (מעל 2 סטיות תקן)";
    const betaTxt = a.betaBased ? `הנגזרת מהבטא של המניה (β ${a.beta.toFixed(2)})` : "המבוססת על תנודתיות שוק ממוצעת (אין בטא זמין)";
    let p = "";
    if(isNum(a.dp) && a.dayLvl!=="normal"){
      p += `המניה ${dirWord} היום ב-<b>${fmtPct(a.dp,2)}</b> — תנועה גדולה פי <b>${a.ratioDay.toFixed(1)}</b> מהתנודתיות היומית הטיפוסית שלה (כ-±${a.sigma.toFixed(1)}%, ${betaTxt}). מדובר בתנועה ${lvlWord}. `;
    } else if(isNum(a.r5) && a.lvl5!=="normal"){
      p += `ב-5 ימי המסחר האחרונים המניה ${a.r5>=0?"עלתה":"ירדה"} ב-<b>${fmtPct(a.r5,2)}</b> — פי <b>${a.ratio5.toFixed(1)}</b> מהטווח השבועי הטיפוסי (כ-±${a.sig5.toFixed(1)}%). מדובר בתנועה ${lvlWord}. `;
    }
    if(a.driver){
      p += `ייתכן שקשור לחדשה מהימים האחרונים: "<a href="${esc(a.driver.url)}" target="_blank" rel="noopener">${esc(a.driver.headline)}</a>" (${esc(a.driver.source||"")}, ${fmtDate(a.driver.datetime)}). `;
    }
    p += `תנועה חריגה כלפי מטה עשויה לשקף חדשה שלילית, אכזבה בדוחות או חולשה ענפית; תנועה חריגה כלפי מעלה — הפתעה חיובית או זרז. כדאי לבדוק את סעיף החדשות לפני הסקת מסקנות.`;
    detail = `<div class="move-detail">${p}</div>`;
  } else {
    detail = `<div class="move-detail">תנועת המחיר הנוכחית נמצאת במסגרת התנודתיות הרגילה של המניה — אין כרגע אירוע מחיר חריג שדורש תשומת לב מיוחדת.</div>`;
  }

  return `<div class="card col-12 movecard ${sigClass}">
    <h2 class="ctitle"><span class="ico">⚡</span>ניתוח תנועת מחיר מול תנודתיות ${tipi("volmove")}<span class="wlbl">Move vs volatility</span></h2>
    <div class="move-rows">${dayRow}${wkRow}</div>
    ${detail}
    <div class="move-note">התנודתיות הטיפוסית מוערכת מהבטא של המניה מול תנודה יומית ממוצעת של השוק (~1%). זהו אומדן — חישוב מדויק של סטיית התקן ההיסטורית דורש היסטוריית מחירים מלאה (פרימיום ב-Finnhub).</div>
  </div>`;
}

function priceCard(Q,M){
  const px=Q&&Q.c, hi=M["52WeekHigh"], lo=M["52WeekLow"];
  const dHi=Q&&Q.h, dLo=Q&&Q.l, dOpen=Q&&Q.o, pc=Q&&Q.pc;
  let yearBar="";
  if(isNum(px)&&isNum(hi)&&isNum(lo)&&hi>lo){
    const p=Math.max(0,Math.min(1,(px-lo)/(hi-lo)));
    yearBar=`<div class="range">
      <div class="rl"><span>טווח 52 שבועות ${tipi("range52")}</span><span class="rlab num">${(p*100).toFixed(0)}% מהטווח</span></div>
      <div class="track"><div class="mark" style="right:${p*100}%"></div></div>
      <div class="ends"><span>${fmtPx(lo)}</span><span>${fmtPx(hi)}</span></div>
    </div>`;
  }
  let dayBar="";
  if(isNum(dHi)&&isNum(dLo)&&dHi>dLo&&isNum(px)){
    const p=Math.max(0,Math.min(1,(px-dLo)/(dHi-dLo)));
    dayBar=`<div class="range">
      <div class="rl"><span>טווח יומי</span><span class="rlab num">פתיחה ${fmtPx(dOpen)}</span></div>
      <div class="track"><div class="mark" style="right:${p*100}%"></div></div>
      <div class="ends"><span>${fmtPx(dLo)}</span><span>${fmtPx(dHi)}</span></div>
    </div>`;
  }
  const rets=[
    ["5 ימים", pick(M,["5DayPriceReturnDaily"])],
    ["3 חודשים", pick(M,["13WeekPriceReturnDaily"])],
    ["6 חודשים", pick(M,["26WeekPriceReturnDaily"])],
    ["מתחילת השנה", pick(M,["yearToDatePriceReturnDaily","ytdPriceReturnDaily"])],
    ["שנה", pick(M,["52WeekPriceReturnDaily"])],
  ];
  const retHtml = rets.map(([k,v])=>`<div class="ret"><div class="rk">${k}</div><div class="rv num ${clsUD(v)}">${fmtPct(v,1)}</div></div>`).join("");
  return `<div class="card col-5">
    <h2 class="ctitle"><span class="ico">📈</span>מחיר וטווח <span class="wlbl">Price &amp; range</span></h2>
    ${yearBar||'<div class="badge-na">אין נתוני טווח שנתי זמינים.</div>'}
    ${dayBar}
    <div class="returns">${retHtml}</div>
  </div>`;
}

/* ---------- sector / sub-sector ETF mapping ---------- */
function sectorMap(ind){
  const s=(ind||"").toLowerCase();
  const has=(...k)=>k.some(x=>s.includes(x));
  let sectorEtf="SPY", sectorName="שוק כללי", subEtf=null, subName=null;
  if(has("semicon")){sectorEtf="XLK";sectorName="טכנולוגיה";subEtf="SMH";subName="שבבים";}
  else if(has("software","internet content","application")){sectorEtf="XLK";sectorName="טכנולוגיה";subEtf="IGV";subName="תוכנה";}
  else if((has("technology","hardware","electronic","information technology")) && !has("biotech")){sectorEtf="XLK";sectorName="טכנולוגיה";}
  else if(has("bank")){sectorEtf="XLF";sectorName="פיננסים";subEtf="KRE";subName="בנקים";}
  else if(has("insurance")){sectorEtf="XLF";sectorName="פיננסים";subEtf="KIE";subName="ביטוח";}
  else if(has("capital market","asset management","financial","credit")){sectorEtf="XLF";sectorName="פיננסים";}
  else if(has("biotech")){sectorEtf="XLV";sectorName="בריאות";subEtf="XBI";subName="ביוטכנולוגיה";}
  else if(has("pharma","drug")){sectorEtf="XLV";sectorName="בריאות";subEtf="PJP";subName="פארמה";}
  else if(has("health","medical","life science")){sectorEtf="XLV";sectorName="בריאות";}
  else if(has("aerospace","defense")){sectorEtf="XLI";sectorName="תעשייה";subEtf="ITA";subName="אווירונאוטיקה וביטחון";}
  else if(has("transport","airline","railroad","logistic","trucking")){sectorEtf="XLI";sectorName="תעשייה";subEtf="IYT";subName="תחבורה";}
  else if((has("industr","machinery","engineering","electrical equipment","building products")) && !has("reit","real estate")){sectorEtf="XLI";sectorName="תעשייה";}
  else if(has("retail")){sectorEtf="XLY";sectorName="צריכה מחזורית";subEtf="XRT";subName="קמעונאות";}
  else if(has("auto")){sectorEtf="XLY";sectorName="צריכה מחזורית";subEtf="CARZ";subName="רכב";}
  else if(has("apparel","restaurant","leisure","hotel","travel","consumer cyclical","discretionary")){sectorEtf="XLY";sectorName="צריכה מחזורית";}
  else if(has("beverage","food","household","tobacco","consumer defensive","staple","grocery")){sectorEtf="XLP";sectorName="צריכה בסיסית";}
  else if(has("media","entertainment","telecom","communication","interactive")){sectorEtf="XLC";sectorName="תקשורת";}
  else if(has("oil","gas","energy","coal","petroleum")){sectorEtf="XLE";sectorName="אנרגיה";if(has("equipment","services")){subEtf="OIH";subName="שירותי נפט";}}
  else if(has("real estate","reit")){sectorEtf="XLRE";sectorName="נדל\"ן";}
  else if(has("utilit")){sectorEtf="XLU";sectorName="תשתיות";}
  else if(has("gold")){sectorEtf="XLB";sectorName="חומרי גלם";subEtf="GDX";subName="זהב";}
  else if(has("mining","metal","steel","copper")){sectorEtf="XLB";sectorName="חומרי גלם";subEtf="XME";subName="כרייה ומתכות";}
  else if(has("material","chemical","paper","container")){sectorEtf="XLB";sectorName="חומרי גלם";}
  return {sectorEtf, sectorName, subEtf, subName};
}

