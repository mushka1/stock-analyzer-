function drawFinTime(){
  const card=document.getElementById("finTimeCard"); if(!card) return;
  if(!finSeries || (!finSeries.annual && !finSeries.quarterly)){
    card.innerHTML=`<h2 class="ctitle"><span class="ico">📈</span>נתונים כספיים לאורך זמן <span class="wlbl">Financials over time</span></h2><div class="badge-na">נתונים היסטוריים אינם זמינים עבור מניה זו בתוכנית החינמית של Finnhub.</div>`;
    return;
  }
  if(!document.getElementById("finMetric")){
    const opts=FIN_METRICS.map(m=>`<option value="${m.v}">${m.label}</option>`).join("");
    card.innerHTML=`<h2 class="ctitle"><span class="ico">📈</span>נתונים כספיים לאורך זמן <span class="wlbl">Financials over time</span></h2>
