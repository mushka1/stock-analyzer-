async function pollQuote(sym){
  if(sym!==liveSym) return;
  try{ const q=await api("/quote",{symbol:sym}); if(sym===liveSym) updateQuoteUI(q); }catch(e){}
}
function updateQuoteUI(Q){
  if(!Q) return;
  const px=document.getElementById("livePx"); if(px&&isNum(Q.c)) px.textContent=fmtPx(Q.c);
  const chg=document.getElementById("liveChg");
  if(chg){ chg.className="chg num "+clsUD(Q.d); chg.textContent=(isNum(Q.d)?(Q.d>=0?"▲ ":"▼ ")+fmtPx(Math.abs(Q.d)):"")+" "+(isNum(Q.dp)?`(${fmtPct(Q.dp)})`:""); }
