/* ---------- price-move vs volatility analysis ---------- */
const MKT_DAILY_SIGMA = 1.0; // approx S&P 500 average daily move (%), baseline
function moveAnalysis(Q, M, NEWS){
  const dp = (Q&&isNum(Q.dp))?Q.dp:null;
  const beta = pick(M,["beta"]);
  const r5 = pick(M,["5DayPriceReturnDaily"]);
  let sigma = isNum(beta) ? Math.abs(beta)*MKT_DAILY_SIGMA : MKT_DAILY_SIGMA;
  sigma = Math.max(0.4, sigma);                       // floor
  const res = {dp, beta, sigma, r5, betaBased:isNum(beta)};
  if(isNum(dp)){
    res.ratioDay = Math.abs(dp)/sigma;
    res.dayLvl = res.ratioDay>=3?"extreme": res.ratioDay>=2?"notable":"normal";
    res.dayDir = dp>=0?1:-1;
  }
  if(isNum(r5)){
    const s5 = sigma*Math.sqrt(5);
    res.sig5 = s5; res.ratio5 = Math.abs(r5)/s5;
    res.lvl5 = res.ratio5>=3?"extreme": res.ratio5>=2?"notable":"normal";
    res.dir5 = r5>=0?1:-1;
  }
  res.significant = (res.dayLvl && res.dayLvl!=="normal") || (res.lvl5 && res.lvl5!=="normal");
  // possible news driver: recent (<54h) item whose sentiment matches today's direction
  res.driver = null;
  if(isNum(dp) && Array.isArray(NEWS) && NEWS.length){
    const now=Date.now()/1000; let best=null, bs=-1;
    for(const n of NEWS){
      if(!n.headline) continue;
      const age=(now-(n.datetime||now))/3600; if(age>54) continue;
      const sen=sentiment((n.headline||"")+" "+(n.summary||""));
      const match = dp>=0 ? sen.net>0 : sen.net<0;
      if(!match) continue;
      const sc = sen.strength*2 + Math.max(0,54-age)/54*2;
      if(sc>bs){ bs=sc; best=n; }
    }
    res.driver=best;
  }
  return res;
}

