    return `<div class="card col-12"><h2 class="ctitle"><span class="ico">📰</span>חדשות <span class="wlbl">News</span></h2><div class="badge-na">אין חדשות זמינות מהחודש האחרון.</div></div>`;
  }
  list.sort((a,b)=>(b.datetime||0)-(a.datetime||0));
  const now=Date.now()/1000;
  const ranked=[...list].map(n=>({n,h:hotScore(n,now)})).sort((a,b)=>b.h-a.h);
  const hot=ranked.slice(0,3).map(x=>x.n);
  const hotUrls=new Set(hot.map(n=>n.url));

  const hotCards = hot.map(n=>{
    const s=sentiment((n.headline||"")+" "+(n.summary||""));
    const sum=shortSummary(n.summary);
    return `<div class="hotcard">
      <div class="hhead"><span class="fire">🔥 חם</span><span class="sent ${s.cls}">${s.t}</span></div>
      <div class="htitle"><a href="${esc(n.url)}" target="_blank" rel="noopener"><span class="to-he" data-en="${esc(n.headline)}">${esc(n.headline)}</span></a></div>
      ${sum?`<div class="hsum to-he" data-en="${esc(sum)}">${esc(sum)}</div>`:""}
      <div class="hmeta">${esc(n.source||"")} · ${fmtDate(n.datetime)}</div>
    </div>`;
  }).join("");

  const more=list.filter(n=>!hotUrls.has(n.url)).slice(0,9).map(n=>{
    const s=sentiment((n.headline||"")+" "+(n.summary||""));
    const thumb = n.image ? `<img class="nthumb" src="${esc(n.image)}" alt="" onerror="this.style.display='none'">` : "";
    return `<div class="news-item">
      ${thumb}
      <div class="nbody">
        <div class="nhead"><a href="${esc(n.url)}" target="_blank" rel="noopener"><span class="to-he" data-en="${esc(n.headline)}">${esc(n.headline)}</span></a></div>
        <div class="nmeta"><span class="nsource">${esc(n.source||"")}</span><span class="num">${fmtDate(n.datetime)}</span><span class="sent ${s.cls}">${s.t}</span></div>
      </div>
    </div>`;
  }).join("");

  return `<div class="card col-12">
    <h2 class="ctitle"><span class="ico">📰</span>חדשות חמות + סיכומים <span class="wlbl">Hot news + summaries</span></h2>
    <p class="csub">3 הידיעות החמות (לפי עדכניות, עוצמת סנטימנט ומקור) עם סיכום קצר בעברית. הכותרות והסיכומים מתורגמים אוטומטית (ייתכנו אי-דיוקי תרגום מכונה); תיוג הסנטימנט היוריסטי.</p>
    <div class="news-hotgrid">${hotCards}</div>
    ${more?`<div class="news-sub">עוד כותרות אחרונות</div>${more}`:""}
  </div>`;
}

