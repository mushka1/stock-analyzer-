/* ---------- news sentiment heuristic ---------- */
const POS = ["beat","beats","surge","surges","soar","soars","jump","jumps","rally","rallies","rallied","record","records","gain","gains","gained","profit","profits","upgrade","upgrades","upgraded","outperform","raises","raised","strong","strength","bullish","top","tops","topped","rises","rose","climbs","climbed","wins","approval","approved","boost","boosts","expands","growth","grows","grew","best","beat","jumps","optimistic","momentum","buyback","dividend"];
const NEG = ["miss","misses","missed","plunge","plunges","plunged","slump","slumps","sink","sinks","tumble","tumbles","drop","drops","dropped","fall","falls","fell","decline","declines","loss","losses","downgrade","downgrades","downgraded","lawsuit","probe","investigation","fraud","recall","warns","warning","cuts","cut","weak","weakness","bearish","slashes","slashed","layoff","layoffs","fears","concern","concerns","sued","halts","disappoints","disappointing","slides","slid","selloff","plummet","plummets"];
const PS_SET=new Set(POS), NS_SET=new Set(NEG);
function sentiment(text){
  const w = (text||"").toLowerCase().match(/[a-z]+/g)||[];
  let p=0,n=0;
  for(const x of w){ if(PS_SET.has(x)) p++; if(NS_SET.has(x)) n++; }
  const net=p-n;
  const t = net>0?"חיובי": net<0?"שלילי":"ניטרלי";
  const cls = net>0?"t-good": net<0?"t-weak":"t-neu";
  return {t,cls,net,strength:Math.abs(net),pos:p,neg:n};
}
function fmtDate(unixSec){
  const d=new Date(unixSec*1000);
  return d.toLocaleDateString("he-IL",{day:"2-digit",month:"2-digit",year:"2-digit"});
}
function shortSummary(s){
  s=(s||"").replace(/\s+/g," ").trim();
  if(!s) return "";
  if(s.length<=200) return s;
  const slice=s.slice(0,205);
  const dot=Math.max(slice.lastIndexOf(". "),slice.lastIndexOf("! "),slice.lastIndexOf("? "));
  if(dot>=110) return slice.slice(0,dot+1);
  const sp=slice.lastIndexOf(" ");
  return slice.slice(0, sp>0?sp:200).trim()+"…";
}
const BIG_SRC=new Set(["reuters","bloomberg","cnbc","wall street journal","the wall street journal","financial times","barron's","barrons","marketwatch","forbes","yahoo","seekingalpha","seeking alpha","associated press","business insider","the motley fool","investor's business daily"]);
function hotScore(n, nowSec){
  let s=0;
  const ageH=(nowSec-(n.datetime||nowSec))/3600;
  s += Math.max(0, 60-ageH)/60*50;                 // recency (last ~60h) up to 50
  const sen=sentiment((n.headline||"")+" "+(n.summary||""));
  s += Math.min(30, sen.strength*9);                // sentiment strength up to 30
  if(BIG_SRC.has((n.source||"").toLowerCase())) s+=12;
  if(n.image) s+=4;
  if((n.summary||"").length>90) s+=4;
  return s;
}

