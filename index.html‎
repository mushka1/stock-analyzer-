      <div class="cmpnote" id="finYoY"></div>`;
  }
  const mk=(document.getElementById("finMetric")||{}).value||"netMargin";
  const freq=(document.getElementById("finFreq")||{}).value||"annual";
  const def=FIN_METRICS.find(m=>m.v===mk)||FIN_METRICS[0];
  const bucket=finSeries[freq]||{};
