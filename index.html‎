  const cv=document.getElementById("finCanvas"), yo=document.getElementById("finYoY");
  if(!arr){ if(finChart){finChart.destroy();finChart=null;} if(yo) yo.textContent="אין נתונים זמינים למדד זה (נסי מדד אחר או תדירות אחרת)."; return; }
  const data=arr.slice().filter(p=>p&&isNum(p.v)).sort((a,b)=>String(a.period).localeCompare(String(b.period)));
  const last=data.slice(-10);
  const labels=last.map(p=>freq==="annual"?String(p.period).slice(0,4):String(p.period).slice(0,7));
  const vals=last.map(p=>+p.v.toFixed(2));
