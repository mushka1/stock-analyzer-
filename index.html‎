  if(finChart) finChart.destroy();
  finChart=new Chart(cv,{type:"bar",data:{labels,datasets:[{label:def.label,data:vals,backgroundColor:"#3f86f4",borderRadius:5,maxBarThickness:46}]},options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false},tooltip:{rtl:true,callbacks:{label:c=>`${def.label}: ${c.parsed.y}${def.unit==="%"?"%":(def.unit==="$"?"":def.unit)}`}}},
    scales:{x:{ticks:{color:"#9db0c8",font:{family:"Inter"}},grid:{display:false}},
      y:{ticks:{color:"#9db0c8",callback:v=>v+(def.unit==="%"?"%":"")},grid:{color:"rgba(38,52,75,0.45)"}}}
  }});
  if(yo && last.length>=2){
    const cur=last[last.length-1].v, prev=last[last.length-2].v;
    const diff=cur-prev, pct=prev!==0?(diff/Math.abs(prev)*100):null, dir=diff>=0?"up":"down";
    const fmtv=x=>def.unit==="%"?x.toFixed(1)+"%":(def.unit==="$"?"$"+x.toFixed(2):x.toFixed(2));
    yo.innerHTML=`השוואה לתקופה קודמת — ${def.label}: <b class="num">${fmtv(cur)}</b> מול <span class="num">${fmtv(prev)}</span> · <span class="${dir} num">${diff>=0?"▲":"▼"} ${isNum(pct)?(pct>=0?"+":"")+pct.toFixed(1)+"%":""}</span>`;
